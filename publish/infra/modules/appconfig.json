{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.43.8.12551",
      "templateHash": "7314791091077115849"
    }
  },
  "parameters": {
    "appName": {
      "type": "string",
      "metadata": {
        "description": "App name prefix"
      }
    },
    "location": {
      "type": "string",
      "metadata": {
        "description": "Azure region"
      }
    },
    "uniqueSuffix": {
      "type": "string",
      "metadata": {
        "description": "Unique suffix for globally unique resource names"
      }
    },
    "tags": {
      "type": "object",
      "metadata": {
        "description": "Resource tags"
      }
    }
  },
  "variables": {
    "appConfigName": "[format('appcs-{0}-{1}', parameters('appName'), parameters('uniqueSuffix'))]"
  },
  "resources": [
    {
      "type": "Microsoft.AppConfiguration/configurationStores",
      "apiVersion": "2023-03-01",
      "name": "[variables('appConfigName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "sku": {
        "name": "standard"
      },
      "properties": {
        "disableLocalAuth": false,
        "enablePurgeProtection": false,
        "softDeleteRetentionInDays": 1,
        "publicNetworkAccess": "Enabled"
      }
    }
  ],
  "outputs": {
    "appConfigName": {
      "type": "string",
      "value": "[variables('appConfigName')]"
    },
    "endpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.AppConfiguration/configurationStores', variables('appConfigName')), '2023-03-01').endpoint]"
    },
    "appConfigId": {
      "type": "string",
      "value": "[resourceId('Microsoft.AppConfiguration/configurationStores', variables('appConfigName'))]"
    }
  }
}