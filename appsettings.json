{
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "Domain": "yourdomain.onmicrosoft.com",
    "TenantId": "your-tenant-id",
    "ClientId": "your-client-id",
    "CallbackPath": "/signin-oidc",
    "SignedOutCallbackPath": "/signout-callback-oidc"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=tcp:<YOUR_SERVER_NAME>.database.windows.net;Database=ContosoUniversity;Authentication=Active Directory Default;"
  },
  "AzureServiceBus": {
    "FullyQualifiedNamespace": "YOUR_SERVICEBUS_NAMESPACE.servicebus.windows.net",
    "QueueName": "notifications"
  },
  "Storage": {
    "ServiceUri": "https://YOUR_STORAGE_ACCOUNT_NAME.blob.core.windows.net",
    "ContainerName": "teaching-materials"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
